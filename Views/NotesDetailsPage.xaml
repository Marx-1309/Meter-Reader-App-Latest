<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MeterReaderApp.ViewModels"
             x:DataType="vm:NotesViewModel"
             x:Class="MeterReaderApp.Views.NotesDetailsPage"
             Title="Note"
             BackgroundColor="{AppThemeBinding Light={StaticResource PageBg}, Dark={StaticResource Ocean900}}">

    <Grid RowDefinitions="*,Auto">
        <ScrollView Grid.Row="0">
            <VerticalStackLayout x:Name="noteForm" Spacing="0"
                                 Opacity="0" TranslationY="20"
                                 Padding="14,8,14,16">

                <Label Text="TITLE" Style="{StaticResource OverlineLabel}" Margin="2,12,0,6" />
                <Frame HasShadow="False" CornerRadius="14" Padding="14,0"
                       HeightRequest="52"
                       BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Ocean700}}"
                       BorderColor="{AppThemeBinding Light=#D0DCE8, Dark={StaticResource Ocean600}}">
                    <Entry Text="{Binding NoteDetails.NoteTitle}"
                           Placeholder="Note title…"
                           FontSize="16" VerticalTextAlignment="Center"
                           TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource Water100}}" />
                </Frame>

                <Label Text="CONTENT" Style="{StaticResource OverlineLabel}" Margin="2,16,0,6" />
                <Frame HasShadow="False" CornerRadius="14" Padding="12"
                       BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Ocean700}}"
                       BorderColor="{AppThemeBinding Light=#D0DCE8, Dark={StaticResource Ocean600}}">
                    <Editor Text="{Binding NoteDetails.NoteContent}"
                            Placeholder="Write something…"
                            FontSize="15" MinimumHeightRequest="160"
                            AutoSize="TextChanges"
                            TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource Water100}}" />
                </Frame>

                <!-- Linked meter photo (from ReadingMedia) -->
                <Label Text="LINKED METER PHOTO" Style="{StaticResource OverlineLabel}"
                       Margin="2,16,0,6" />
                <Frame HasShadow="False" CornerRadius="16" Padding="0"
                       BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Ocean800}}"
                       BorderColor="{AppThemeBinding Light=#E8EDF2, Dark={StaticResource Ocean700}}">
                    <Grid RowDefinitions="Auto,Auto">
                        <!-- Photo display -->
                        <Grid Grid.Row="0" HeightRequest="200"
                              BackgroundColor="{AppThemeBinding Light={StaticResource N50}, Dark={StaticResource Ocean700}}">
                            <!-- Placeholder when no photo -->
                            <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="8">
                                <VerticalStackLayout.Triggers>
                                    <DataTrigger TargetType="VerticalStackLayout"
                                                 Binding="{Binding HasLinkedPhoto}" Value="True">
                                        <Setter Property="IsVisible" Value="False" />
                                    </DataTrigger>
                                </VerticalStackLayout.Triggers>
                                <Label Text="📷" FontSize="40" HorizontalOptions="Center" />
                                <Label Text="No photo linked to this note"
                                       FontSize="13"
                                       TextColor="{AppThemeBinding Light={StaticResource TextTertiary}, Dark={StaticResource N500}}"
                                       HorizontalOptions="Center" />
                            </VerticalStackLayout>
                            <!-- Actual photo -->
                            <Image Source="{Binding LinkedPhotoSource}"
                                   Aspect="AspectFit"
                                   IsVisible="{Binding HasLinkedPhoto}"
                                   HeightRequest="200">
                                <Image.Clip>
                                    <RoundRectangleGeometry CornerRadius="16,16,0,0"
                                        Rect="0,0,9999,200" />
                                </Image.Clip>
                            </Image>
                        </Grid>

                        <!-- Photo meta row -->
                        <Grid Grid.Row="1" Padding="14,10" ColumnDefinitions="*,Auto"
                              IsVisible="{Binding HasLinkedPhoto}">
                            <VerticalStackLayout Spacing="2">
                                <Label Text="{Binding LinkedPhotoTitle}"
                                       FontSize="13" FontFamily="OpenSansSemibold"
                                       TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource Water100}}"
                                       LineBreakMode="TailTruncation" />
                                <Label Text="{Binding LinkedPhotoDate}" FontSize="11"
                                       TextColor="{AppThemeBinding Light={StaticResource TextTertiary}, Dark={StaticResource N500}}" />
                            </VerticalStackLayout>
                            <Border Grid.Column="1"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource TeleBlueLight}, Dark={StaticResource Ocean700}}"
                                    StrokeShape="RoundRectangle 10" StrokeThickness="0"
                                    Padding="10,6" VerticalOptions="Center">
                                <Label Text="View Full" FontSize="12" FontFamily="OpenSansSemibold"
                                       TextColor="{AppThemeBinding Light={StaticResource TeleBlue}, Dark={StaticResource Water300}}">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding ViewLinkedPhotoCommand}" />
                                    </Label.GestureRecognizers>
                                </Label>
                            </Border>
                        </Grid>
                    </Grid>
                </Frame>

                <!-- Date -->
                <HorizontalStackLayout Spacing="8" Margin="2,16,0,0">
                    <Label Text="🗓" FontSize="13" VerticalOptions="Center" />
                    <Label Text="{Binding NoteDetails.Date}" FontSize="13"
                           TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource N400}}"
                           VerticalOptions="Center" />
                </HorizontalStackLayout>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Save button -->
        <VerticalStackLayout Grid.Row="1" Padding="14,10,14,32" Spacing="0"
                             BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Ocean800}}">
            <BoxView HeightRequest="1" Margin="0,0,0,12"
                     Color="{AppThemeBinding Light=#E8EDF2, Dark={StaticResource Ocean700}}" />
            <Button Text="Save Note" Style="{StaticResource BtnOcean}"
                    Command="{Binding UpsertNoteCommand}" />
        </VerticalStackLayout>

        <!-- Full photo overlay -->
        <Grid IsVisible="{Binding IsPhotoViewerOpen}"
              BackgroundColor="#EE000000" Grid.RowSpan="2">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding ClosePhotoViewerCommand}" />
            </Grid.GestureRecognizers>
            <VerticalStackLayout VerticalOptions="Center">
                <Grid Padding="16,12" ColumnDefinitions="*,Auto">
                    <Label Text="{Binding LinkedPhotoTitle}"
                           FontSize="15" FontFamily="OpenSansSemibold" TextColor="White" />
                    <Label Grid.Column="1" Text="✕" FontSize="22" TextColor="White"
                           Padding="10,0">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ClosePhotoViewerCommand}" />
                        </Label.GestureRecognizers>
                    </Label>
                </Grid>
                <Image Source="{Binding LinkedPhotoSource}" Aspect="AspectFit"
                       HorizontalOptions="Fill" MaximumHeightRequest="520" />
            </VerticalStackLayout>
        </Grid>
    </Grid>
</ContentPage>
