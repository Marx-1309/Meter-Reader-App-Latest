<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:SampleMauiMvvmApp.ViewModels"
             x:DataType="vm:GalleryViewModel"
             x:Class="SampleMauiMvvmApp.Views.GalleryPage"
             Title="Photo Gallery"
             BackgroundColor="{AppThemeBinding Light={StaticResource PageBg}, Dark={StaticResource Ocean900}}">

    <Grid>

        <!-- ── Main list ── -->
        <Grid RowDefinitions="Auto,*">

            <!-- Header -->
            <Grid Grid.Row="0" Padding="20,18,20,26" MinimumHeightRequest="110">
                <Grid.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#1A3A5C" Offset="0.0" />
                        <GradientStop Color="#1A7DB5" Offset="0.6" />
                        <GradientStop Color="#2AABEE" Offset="1.0" />
                    </LinearGradientBrush>
                </Grid.Background>
                <Ellipse Fill="#1A2DD4BF" WidthRequest="150" HeightRequest="150"
                         HorizontalOptions="End" VerticalOptions="Start"
                         Margin="0,-50,-40,0" />
                <Grid ColumnDefinitions="*,Auto" VerticalOptions="Center">
                    <VerticalStackLayout Spacing="2">
                        <Label Text="Meter Photos"
                               FontSize="22" FontFamily="OpenSansSemibold" TextColor="White" />
                        <Label Text="{Binding Photos.Count, StringFormat='{0} captured image(s)'}"
                               FontSize="12" TextColor="#BBCFE9F8" />
                    </VerticalStackLayout>
                    <Border Grid.Column="1"
                            BackgroundColor="#22FFFFFF"
                            StrokeShape="RoundRectangle 12" StrokeThickness="0"
                            Padding="12,8" VerticalOptions="Center">
                        <Label Text="Refresh" FontSize="13" FontFamily="OpenSansSemibold"
                               TextColor="White">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding LoadPhotosCommand}" />
                            </Label.GestureRecognizers>
                        </Label>
                    </Border>
                </Grid>
            </Grid>

            <!-- Wave -->
            <BoxView Grid.Row="1" HeightRequest="20" VerticalOptions="Start"
                     Margin="0,-10,0,0" CornerRadius="20,20,0,0"
                     BackgroundColor="{AppThemeBinding Light={StaticResource PageBg}, Dark={StaticResource Ocean900}}" />

            <!-- Photo grid -->
            <CollectionView x:Name="photoGrid" Grid.Row="1"
                            ItemsSource="{Binding Photos}"
                            SelectionMode="None"
                            Margin="10,16,10,0">
                <CollectionView.ItemsLayout>
                    <GridItemsLayout Orientation="Vertical" Span="2"
                                     HorizontalItemSpacing="8" VerticalItemSpacing="8" />
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:GalleryItem">
                        <Border BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Ocean800}}"
                                StrokeShape="RoundRectangle 16" StrokeThickness="0"
                                Margin="2">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:GalleryViewModel}}, Path=OpenPhotoCommand}"
                                    CommandParameter="{Binding .}" />
                            </Border.GestureRecognizers>

                            <Grid RowDefinitions="140,Auto">
                                <!-- Photo tile -->
                                <Image Grid.Row="0" Source="{Binding Source}"
                                       Aspect="AspectFill" HeightRequest="140">
                                    <Image.Clip>
                                        <RoundRectangleGeometry CornerRadius="16,16,0,0"
                                            Rect="0,0,999,140" />
                                    </Image.Clip>
                                </Image>

                                <!-- Sync badge -->
                                <Border Grid.Row="0"
                                        BackgroundColor="{Binding SyncColor}"
                                        StrokeShape="RoundRectangle 8" StrokeThickness="0"
                                        Padding="7,3" HorizontalOptions="End"
                                        VerticalOptions="Start" Margin="0,8,8,0">
                                    <Label Text="{Binding SyncLabel}"
                                           FontSize="10" FontFamily="OpenSansSemibold"
                                           TextColor="White" />
                                </Border>

                                <!-- Meta -->
                                <VerticalStackLayout Grid.Row="1" Padding="10,8,10,10" Spacing="2">
                                    <Label Text="{Binding Title}"
                                           FontSize="13" FontFamily="OpenSansSemibold"
                                           LineBreakMode="TailTruncation"
                                           TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource Water100}}" />
                                    <Label Text="{Binding DateTaken}"
                                           FontSize="10"
                                           TextColor="{AppThemeBinding Light={StaticResource TextTertiary}, Dark={StaticResource N500}}" />
                                </VerticalStackLayout>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>

                <CollectionView.EmptyView>
                    <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center"
                                         Spacing="14" Padding="40">
                        <Label Text="📷" FontSize="56" HorizontalOptions="Center" />
                        <Label Text="No photos yet"
                               FontSize="17" FontFamily="OpenSansSemibold"
                               HorizontalOptions="Center"
                               TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource N400}}" />
                        <Label Text="Capture meter photos when recording a reading"
                               FontSize="13" HorizontalOptions="Center" HorizontalTextAlignment="Center"
                               TextColor="{AppThemeBinding Light={StaticResource TextTertiary}, Dark={StaticResource N500}}" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
            </CollectionView>

            <ActivityIndicator Grid.Row="1" IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                               HorizontalOptions="Center" VerticalOptions="Center" />
        </Grid>

        <!-- ── Full-screen photo viewer overlay ── -->
        <Grid IsVisible="{Binding IsViewerOpen}"
              BackgroundColor="#EE000000">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding CloseViewerCommand}" />
            </Grid.GestureRecognizers>

            <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Fill"
                                 Spacing="0">

                <!-- Close bar -->
                <Grid Padding="16,12" ColumnDefinitions="*,Auto">
                    <VerticalStackLayout Spacing="2">
                        <Label Text="{Binding SelectedPhoto.Title}"
                               FontSize="16" FontFamily="OpenSansSemibold" TextColor="White"
                               LineBreakMode="TailTruncation" />
                        <Label Text="{Binding SelectedPhoto.DateTaken}"
                               FontSize="12" TextColor="#AAFFFFFF" />
                    </VerticalStackLayout>
                    <Border Grid.Column="1"
                            BackgroundColor="#44FFFFFF"
                            StrokeShape="RoundRectangle 20" StrokeThickness="0"
                            HeightRequest="40" WidthRequest="40" VerticalOptions="Center">
                        <Label Text="✕" FontSize="18" TextColor="White"
                               HorizontalOptions="Center" VerticalOptions="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding CloseViewerCommand}" />
                            </Label.GestureRecognizers>
                        </Label>
                    </Border>
                </Grid>

                <!-- Full image -->
                <Image Source="{Binding SelectedPhoto.Source}"
                       Aspect="AspectFit" HorizontalOptions="Fill"
                       MaximumHeightRequest="500">
                    <Image.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding CloseViewerCommand}" NumberOfTapsRequired="2" />
                    </Image.GestureRecognizers>
                </Image>

                <!-- Actions -->
                <Grid ColumnDefinitions="*,*" Padding="16,16" ColumnSpacing="10">
                    <Button Grid.Column="0" Text="Close" Style="{StaticResource BtnOutline}"
                            Command="{Binding CloseViewerCommand}"
                            TextColor="White" BorderColor="White" />
                    <Button Grid.Column="1" Text="Delete" Style="{StaticResource BtnDanger}"
                            Command="{Binding DeletePhotoCommand}"
                            CommandParameter="{Binding SelectedPhoto}" />
                </Grid>
            </VerticalStackLayout>
        </Grid>

    </Grid>
</ContentPage>
