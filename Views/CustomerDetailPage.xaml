<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="MeterReaderApp.Views.CustomerDetailPage"
             xmlns:viewmodel="clr-namespace:MeterReaderApp.ViewModels"
             x:DataType="viewmodel:CustomerDetailViewModel"
             Title="{Binding Title}"
             BackgroundColor="{AppThemeBinding Light={StaticResource PageBg}, Dark={StaticResource Ocean900}}">

    <ContentPage.Resources>
        <Color x:Key="PageBackgroundColor">#F0F4F8</Color>
        <Color x:Key="CardBackgroundColor">#FFFFFF</Color>
        <Color x:Key="PrimaryTextColor">#0A2342</Color>
        <Color x:Key="SecondaryTextColor">#4A7A9B</Color>
        <Color x:Key="AccentColor">#2AABEE</Color>
        <Color x:Key="DangerColor">#E53935</Color>
        <Color x:Key="BorderColor">#D0E8F5</Color>
        <Color x:Key="InputBackgroundColor">#FFFFFF</Color>

        <Style x:Key="CardView" TargetType="Frame">
            <Setter Property="HasShadow"    Value="False" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Padding"      Value="16" />
            <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Ocean800}}" />
            <Setter Property="BorderColor"     Value="{AppThemeBinding Light=#E8EDF2, Dark={StaticResource Ocean700}}" />
        </Style>
        <Style x:Key="HeaderLabel" TargetType="Label">
            <Setter Property="FontSize"         Value="11" />
            <Setter Property="FontFamily"       Value="OpenSansSemibold" />
            <Setter Property="CharacterSpacing" Value="1.2" />
            <Setter Property="TextColor"        Value="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource N400}}" />
            <Setter Property="Margin"           Value="0,16,0,6" />
        </Style>
        <Style x:Key="FieldTitleLabel" TargetType="Label">
            <Setter Property="FontSize"         Value="11" />
            <Setter Property="FontFamily"       Value="OpenSansSemibold" />
            <Setter Property="CharacterSpacing" Value="0.8" />
            <Setter Property="TextColor"        Value="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource N400}}" />
        </Style>
        <Style x:Key="FieldValueLabel" TargetType="Label">
            <Setter Property="FontSize"   Value="17" />
            <Setter Property="FontFamily" Value="OpenSansSemibold" />
            <Setter Property="TextColor"  Value="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource Water100}}" />
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="BackgroundColor"  Value="{AppThemeBinding Light={StaticResource TeleBlue}, Dark={StaticResource Water300}}" />
            <Setter Property="TextColor"        Value="White" />
            <Setter Property="CornerRadius"     Value="14" />
            <Setter Property="HeightRequest"    Value="52" />
            <Setter Property="FontFamily"       Value="OpenSansSemibold" />
        </Style>
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="BackgroundColor" Value="Transparent" />
            <Setter Property="TextColor"   Value="{AppThemeBinding Light={StaticResource TeleBlue}, Dark={StaticResource Water300}}" />
            <Setter Property="BorderColor" Value="{AppThemeBinding Light={StaticResource TeleBlue}, Dark={StaticResource Water300}}" />
            <Setter Property="BorderWidth" Value="1.5" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="HeightRequest" Value="52" />
            <Setter Property="FontFamily" Value="OpenSansSemibold" />
        </Style>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout x:Name="detailPanel" Spacing="0" Padding="14,4,14,32"
                             Opacity="0" TranslationY="20">

            <!-- CUSTOMER DETAILS -->
            <Label Text="CUSTOMER DETAILS" Style="{StaticResource HeaderLabel}" />
            <Frame Style="{StaticResource CardView}">
                <VerticalStackLayout Spacing="14">
                    <Grid ColumnDefinitions="*,Auto">
                        <VerticalStackLayout Spacing="2">
                            <Label Text="AREA" Style="{StaticResource FieldTitleLabel}" />
                            <Label Text="{Binding CustStateErf}" Style="{StaticResource FieldValueLabel}"
                                   TextColor="{AppThemeBinding Light={StaticResource TeleBlue}, Dark={StaticResource Water200}}" />
                        </VerticalStackLayout>
                        <Border Style="{StaticResource iconBtnContainer}" Grid.Column="1">
                            <ImageButton Source="pencil_icon.jpg" Command="{Binding UpdateCustomerLocationCommand}"
                                         BackgroundColor="Transparent" HeightRequest="22" WidthRequest="22" />
                        </Border>
                    </Grid>

                    <BoxView Style="{StaticResource WaterDivider}" />

                    <Grid ColumnDefinitions="*,Auto">
                        <VerticalStackLayout Spacing="3">
                            <Label Text="LOCATION" Style="{StaticResource FieldTitleLabel}" />
                            <HorizontalStackLayout Spacing="6">
                                <Label Text="{Binding Latitude, StringFormat='Lat: {0}'}" FontSize="Micro" />
                                <Image WidthRequest="14" HeightRequest="14" Margin="2,0">
                                    <Image.Triggers>
                                        <DataTrigger TargetType="Image" Binding="{Binding IsLocationSet}" Value="True">
                                            <Setter Property="Source" Value="success_icon.jpg" />
                                        </DataTrigger>
                                        <DataTrigger TargetType="Image" Binding="{Binding IsLocationSet}" Value="False">
                                            <Setter Property="Source" Value="failed_icon.png" />
                                        </DataTrigger>
                                    </Image.Triggers>
                                </Image>
                            </HorizontalStackLayout>
                            <HorizontalStackLayout Spacing="6">
                                <Label Text="{Binding Longitude, StringFormat='Lon: {0}'}" FontSize="Micro" />
                                <Image WidthRequest="14" HeightRequest="14" Margin="2,0">
                                    <Image.Triggers>
                                        <DataTrigger TargetType="Image" Binding="{Binding IsLocationSet}" Value="True">
                                            <Setter Property="Source" Value="success_icon.jpg" />
                                        </DataTrigger>
                                        <DataTrigger TargetType="Image" Binding="{Binding IsLocationSet}" Value="False">
                                            <Setter Property="Source" Value="failed_icon.png" />
                                        </DataTrigger>
                                    </Image.Triggers>
                                </Image>
                            </HorizontalStackLayout>
                            <Label Text="Location Not Set"
                                   TextColor="{AppThemeBinding Light={StaticResource Danger500}, Dark={StaticResource Danger500}}"
                                   FontSize="{Binding Source={x:Reference MeterNumberLabel}, Path=FontSize}">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label" Binding="{Binding IsLocationSet}" Value="True">
                                        <Setter Property="IsVisible" Value="False" />
                                    </DataTrigger>
                                    <DataTrigger TargetType="Label" Binding="{Binding IsLocationSet}" Value="False">
                                        <Setter Property="IsVisible" Value="True" />
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>
                        </VerticalStackLayout>
                        <Border Style="{StaticResource iconBtnContainer}" Grid.Column="1">
                            <ImageButton Source="map_icon.png" Command="{Binding OpenMapPageCommand}"
                                         BackgroundColor="Transparent" HeightRequest="22" WidthRequest="22" />
                        </Border>
                    </Grid>

                    <BoxView Style="{StaticResource WaterDivider}" />

                    <Grid ColumnDefinitions="*,Auto">
                        <VerticalStackLayout Spacing="2">
                            <!-- x:Name MUST stay — code-behind references it -->
                            <Label Text="METER NO" Style="{StaticResource FieldTitleLabel}" x:Name="MeterNumberLabel" />
                            <Label Text="{Binding MeterNumber}" Style="{StaticResource FieldValueLabel}" />
                        </VerticalStackLayout>
                        <Border Style="{StaticResource iconBtnContainer}" Grid.Column="1">
                            <ImageButton Source="pencil_icon.jpg" Command="{Binding UpdateCustomerMeterNoCommand}"
                                         BackgroundColor="Transparent" HeightRequest="22" WidthRequest="22" />
                        </Border>
                    </Grid>

                    <BoxView Style="{StaticResource WaterDivider}" />
                    <VerticalStackLayout Spacing="2">
                        <Label Text="PHONE NO" Style="{StaticResource FieldTitleLabel}" />
                        <Label Text="{Binding Custphone1}" Style="{StaticResource FieldValueLabel}" />
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Frame>

            <!-- METER READINGS -->
            <Label Text="METER READINGS" Style="{StaticResource HeaderLabel}" />
            <Frame Style="{StaticResource CardView}">
                <VerticalStackLayout Spacing="14">
                    <Grid ColumnDefinitions="*,1,*">
                        <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                            <Label Text="PREVIOUS" Style="{StaticResource FieldTitleLabel}" HorizontalOptions="Center" />
                            <Border BackgroundColor="{AppThemeBinding Light={StaticResource N50}, Dark={StaticResource Ocean700}}"
                                    StrokeShape="RoundRectangle 12" StrokeThickness="0" Padding="14,8">
                                <Label Text="{Binding CustPrevReading}" FontSize="30" FontFamily="OpenSansSemibold"
                                       TextColor="{AppThemeBinding Light={StaticResource N400}, Dark={StaticResource N400}}"
                                       HorizontalOptions="Center" />
                            </Border>
                        </VerticalStackLayout>
                        <BoxView Grid.Column="1" WidthRequest="1" VerticalOptions="Fill" Margin="0,8"
                                 Color="{AppThemeBinding Light=#E8EDF2, Dark={StaticResource Ocean700}}" />
                        <VerticalStackLayout Grid.Column="2" Spacing="4" HorizontalOptions="Center">
                            <Label Text="CURRENT" Style="{StaticResource FieldTitleLabel}" HorizontalOptions="Center" />
                            <Border BackgroundColor="{AppThemeBinding Light={StaticResource TeleBlueLight}, Dark={StaticResource Ocean700}}"
                                    StrokeShape="RoundRectangle 12" StrokeThickness="0" Padding="14,8">
                                <Label Text="{Binding CustCurrentReading}" FontSize="30" FontFamily="OpenSansSemibold"
                                       TextColor="{AppThemeBinding Light={StaticResource TeleBlue}, Dark={StaticResource Water200}}"
                                       HorizontalOptions="Center" />
                            </Border>
                        </VerticalStackLayout>
                    </Grid>

                    <VerticalStackLayout IsVisible="{Binding IsCurrentReading}" Spacing="4" HorizontalOptions="Center">
                        <BoxView Style="{StaticResource WaterDivider}" />
                        <Label Text="TOTAL USAGE" Style="{StaticResource FieldTitleLabel}" HorizontalOptions="Center" />
                        <Border BackgroundColor="{AppThemeBinding Light={StaticResource Danger100}, Dark={StaticResource Ocean700}}"
                                StrokeShape="RoundRectangle 12" StrokeThickness="0"
                                Padding="18,8" HorizontalOptions="Center">
                            <Label Text="{Binding TotalUsage}" FontSize="26" FontFamily="OpenSansSemibold"
                                   TextColor="{AppThemeBinding Light={StaticResource Danger500}, Dark={StaticResource Danger500}}"
                                   HorizontalOptions="Center" />
                        </Border>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Frame>

            <!-- NEW ENTRY -->
            <Label Text="NEW ENTRY" Style="{StaticResource HeaderLabel}" />
            <Frame Style="{StaticResource CardView}">
                <VerticalStackLayout Spacing="12">

                    <!-- Reading input -->
                    <Frame Style="{StaticResource WaterInput}" HeightRequest="52">
                        <Entry Placeholder="Enter new reading here" Keyboard="Numeric"
                               Text="{Binding VmReading.C_reading}"
                               FontSize="16" VerticalTextAlignment="Center" />
                    </Frame>

                    <!-- ═══ ACCORDION: Comment & Photo ═══ -->
                    <Frame HasShadow="False" CornerRadius="14" Padding="0"
                           BackgroundColor="{AppThemeBinding Light={StaticResource N50}, Dark={StaticResource Ocean700}}"
                           BorderColor="{AppThemeBinding Light=#D0E8F5, Dark={StaticResource Ocean600}}">
                        <toolkit:Expander>
                            <toolkit:Expander.Header>
                                <Grid ColumnDefinitions="Auto,*,Auto" Padding="14,12">
                                    <!-- Icon -->
                                    <Border BackgroundColor="{AppThemeBinding Light={StaticResource TeleBlueLight}, Dark={StaticResource Ocean800}}"
                                            StrokeShape="RoundRectangle 10" StrokeThickness="0"
                                            HeightRequest="36" WidthRequest="36" VerticalOptions="Center">
                                        <Label Text="✎" FontSize="17"
                                               TextColor="{AppThemeBinding Light={StaticResource TeleBlue}, Dark={StaticResource Water300}}"
                                               HorizontalOptions="Center" VerticalOptions="Center" />
                                    </Border>
                                    <VerticalStackLayout Grid.Column="1" Spacing="1" Padding="12,0,0,0"
                                                         VerticalOptions="Center">
                                        <Label Text="Comment &amp; Photo"
                                               FontSize="14" FontFamily="OpenSansSemibold"
                                               TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource Water100}}" />
                                        <Label Text="Optional — tap to expand"
                                               FontSize="12"
                                               TextColor="{AppThemeBinding Light={StaticResource TextTertiary}, Dark={StaticResource N400}}" />
                                    </VerticalStackLayout>
                                    <Label Grid.Column="2" Text="›" FontSize="20"
                                           TextColor="{AppThemeBinding Light={StaticResource TeleBlue}, Dark={StaticResource Water300}}"
                                           VerticalOptions="Center" />
                                </Grid>
                            </toolkit:Expander.Header>

                            <!-- Expanded body -->
                            <VerticalStackLayout Padding="14,0,14,14" Spacing="12">
                                <BoxView HeightRequest="1" Margin="0,0,0,4"
                                         Color="{AppThemeBinding Light=#D0E8F5, Dark={StaticResource Ocean600}}" />

                                <!-- Comment editor -->
                                <VerticalStackLayout Spacing="6">
                                    <Label Text="COMMENT" Style="{StaticResource OverlineLabel}" />
                                    <Frame HasShadow="False" CornerRadius="12" Padding="12"
                                           BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Ocean800}}"
                                           BorderColor="{AppThemeBinding Light=#E8EDF2, Dark={StaticResource Ocean600}}">
                                        <Editor Placeholder="Type your comment here..."
                                                AutoSize="TextChanges"
                                                Text="{Binding VmReading.Comment}"
                                                MinimumHeightRequest="80" />
                                    </Frame>
                                </VerticalStackLayout>

                                <!-- Camera section -->
                                <VerticalStackLayout Spacing="6">
                                    <Label Text="PHOTO" Style="{StaticResource OverlineLabel}" />
                                    <Frame HasShadow="False" CornerRadius="12" Padding="14,12"
                                           BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Ocean800}}"
                                           BorderColor="{AppThemeBinding Light=#E8EDF2, Dark={StaticResource Ocean600}}">
                                        <Grid ColumnDefinitions="Auto,*,Auto">
                                            <!-- Camera icon chip -->
                                            <!--<Border BackgroundColor="{AppThemeBinding Light={StaticResource TeleBlueLight}, Dark={StaticResource Ocean700}}"
                                                    StrokeShape="RoundRectangle 12" StrokeThickness="0"
                                                    HeightRequest="44" WidthRequest="44" VerticalOptions="Center">
                                                <Label Text="⌷" FontSize="22"
                                                       TextColor="{AppThemeBinding Light={StaticResource TeleBlue}, Dark={StaticResource Water300}}"
                                                       HorizontalOptions="Center" VerticalOptions="Center" />
                                            </Border>-->
                                            <VerticalStackLayout Grid.Column="1" Spacing="2" Padding="12,0,0,0"
                                                                 VerticalOptions="Center">
                                                <Label Text="Attach meter photo"
                                                       FontSize="14" FontFamily="OpenSansSemibold"
                                                       TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource Water100}}" />
                                                <Label Text="Tap to open camera"
                                                       FontSize="12"
                                                       TextColor="{AppThemeBinding Light={StaticResource TextTertiary}, Dark={StaticResource N400}}" />
                                            </VerticalStackLayout>
                                            <!-- Camera button — TakePhotoClickedCommand kept -->
                                            <Border Grid.Column="2"
                                                    BackgroundColor="{AppThemeBinding Light={StaticResource TeleBlue}, Dark={StaticResource Water300}}"
                                                    StrokeShape="RoundRectangle 10" StrokeThickness="0"
                                                    HeightRequest="40" WidthRequest="40" VerticalOptions="Center">
                                                <ImageButton Source="camera_icon.jpg"
                                                             Command="{Binding TakePhotoClickedCommand}"
                                                             BackgroundColor="Transparent"
                                                             HeightRequest="22" WidthRequest="22"
                                                             HorizontalOptions="Center" VerticalOptions="Center" />
                                            </Border>
                                        </Grid>
                                    </Frame>
                                </VerticalStackLayout>
                            </VerticalStackLayout>
                        </toolkit:Expander>
                    </Frame>

                </VerticalStackLayout>
            </Frame>

            <!-- Action buttons -->
            <VerticalStackLayout Spacing="10" Margin="0,16,0,0">
                <!-- CreateReadingCommand + IsUpdate trigger kept exactly -->
                <Button Style="{StaticResource PrimaryButton}" Text="Save Reading"
                        Command="{Binding CreateReadingCommand}">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button" Binding="{Binding IsUpdate}" Value="true">
                            <Setter Property="Text" Value="Update Reading" />
                            <Setter Property="BackgroundColor" Value="{StaticResource DangerColor}" />
                        </DataTrigger>
                    </Button.Triggers>
                </Button>
                <Button Text="Go Back" Style="{StaticResource SecondaryButton}"
                        Command="{Binding GoBackCommand}" />
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
