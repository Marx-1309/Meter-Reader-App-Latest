<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodel="clr-namespace:MeterReaderApp.ViewModels"
             xmlns:models="clr-namespace:MeterReaderApp.Models"
             x:DataType="viewmodel:MenuViewModel"
             x:Class="MeterReaderApp.Views.MenuPage"
             Title="Menu"
             BackgroundColor="{AppThemeBinding Light={StaticResource PageBg}, Dark={StaticResource Ocean900}}">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Analytics-style greeting header -->
        <Grid Grid.Row="0" Padding="20,20,20,30" MinimumHeightRequest="120">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#1A3A5C" Offset="0.0" />
                    <GradientStop Color="#1A7DB5" Offset="0.6" />
                    <GradientStop Color="#2AABEE" Offset="1.0" />
                </LinearGradientBrush>
            </Grid.Background>
            <Ellipse Fill="#1A2DD4BF" WidthRequest="160" HeightRequest="160"
                     HorizontalOptions="End" VerticalOptions="Start"
                     Margin="0,-60,-50,0" />
            <Ellipse Fill="#0E7CE3FA" WidthRequest="90" HeightRequest="90"
                     HorizontalOptions="End" VerticalOptions="End"
                     Margin="0,0,70,-30" />
            <VerticalStackLayout Spacing="3" VerticalOptions="Center">
                <Label Text="{Binding Greeting}"
                       FontSize="22" FontFamily="OpenSansSemibold" TextColor="White" />
                <Label Text="{Binding TodayDate}"
                       FontSize="12" TextColor="#BBCFE9F8" />
                <Label Text="{Binding LoggedUser, StringFormat='Welcome, {0}'}"
                       FontSize="13" TextColor="#88CFE9F8" Margin="0,4,0,0" />
            </VerticalStackLayout>
        </Grid>

        <!-- Wave cutout -->
        <BoxView Grid.Row="1" HeightRequest="22" VerticalOptions="Start"
                 Margin="0,-12,0,0" CornerRadius="22,22,0,0" ZIndex="1"
                 BackgroundColor="{AppThemeBinding Light={StaticResource PageBg}, Dark={StaticResource Ocean900}}" />

        <!-- Menu grid — DataTemplate has x:DataType="models:Menu" so bindings resolve -->
        <CollectionView x:Name="menuGrid" Grid.Row="1"
                        ItemsSource="{Binding Menus}"
                        Margin="10,20,10,0">
            <CollectionView.ItemsLayout>
                <GridItemsLayout Orientation="Vertical" Span="2"
                                 HorizontalItemSpacing="10" VerticalItemSpacing="10" />
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Menu">
                    <Frame Padding="0" Margin="2,0" CornerRadius="18" HasShadow="False"
                           BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Ocean800}}"
                           BorderColor="{AppThemeBinding Light=#E8EDF2, Dark={StaticResource Ocean700}}">
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer
                                Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:MenuViewModel}}, Path=GoToDetailsCommand}"
                                CommandParameter="{Binding .}" />
                        </Frame.GestureRecognizers>

                        <VerticalStackLayout Spacing="10" Padding="14,18"
                                             HorizontalOptions="Center">
                            <Border BackgroundColor="{AppThemeBinding Light={StaticResource TeleBlueLight}, Dark={StaticResource Ocean700}}"
                                    StrokeShape="RoundRectangle 16" StrokeThickness="0"
                                    HeightRequest="60" WidthRequest="60"
                                    HorizontalOptions="Center">
                                <Image Source="{Binding Image}"
                                       HeightRequest="32" WidthRequest="32"
                                       Aspect="AspectFit"
                                       HorizontalOptions="Center" VerticalOptions="Center" />
                            </Border>
                            <Label Text="{Binding Name}"
                                   FontSize="13" FontFamily="OpenSansSemibold"
                                   HorizontalOptions="Center"
                                   HorizontalTextAlignment="Center"
                                   MaxLines="2" LineBreakMode="WordWrap"
                                   TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource Water100}}" />
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Sign Out -->
        <VerticalStackLayout Grid.Row="2" Padding="14,10,14,32" Spacing="0"
                             BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Ocean800}}">
            <BoxView HeightRequest="1" Margin="0,0,0,12"
                     Color="{AppThemeBinding Light=#E8EDF2, Dark={StaticResource Ocean700}}" />
            <Button Text="Sign Out" Style="{StaticResource BtnDanger}"
                    Command="{Binding ConfirmLogoutCommand}" />
        </VerticalStackLayout>

    </Grid>
</ContentPage>
