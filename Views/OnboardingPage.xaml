<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SampleMauiMvvmApp.Views.OnboardingPage"
             Shell.NavBarIsVisible="False"
             Shell.FlyoutBehavior="Disabled">

    <Grid>
        <!-- Ocean background -->
        <BoxView>
            <BoxView.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#061929" Offset="0.0" />
                    <GradientStop Color="#0E5C8C" Offset="0.6" />
                    <GradientStop Color="#1A9BC7" Offset="1.0" />
                </LinearGradientBrush>
            </BoxView.Background>
        </BoxView>
        <Ellipse Fill="#1A2DD4BF" WidthRequest="300" HeightRequest="300"
                 HorizontalOptions="End" VerticalOptions="Start" Margin="0,-100,-100,0" />

        <Grid RowDefinitions="*,*">
            <Border Grid.Row="0" HeightRequest="260" WidthRequest="260"
                    HorizontalOptions="Center" VerticalOptions="Center"
                    Stroke="#554ABFDA" StrokeShape="RoundRectangle 130" StrokeThickness="4"
                    IsVisible="{OnPlatform False, Android=True}">
                <Image Aspect="AspectFill" HeightRequest="260" WidthRequest="260"
                       Source="onboarding_icon.png" />
                <Border.Shadow>
                    <Shadow Brush="#440E5C8C" Radius="60" />
                </Border.Shadow>
            </Border>
            <Frame Grid.Row="0" HeightRequest="260" WidthRequest="260"
                   HorizontalOptions="Center" VerticalOptions="Center"
                   BorderColor="#554ABFDA" CornerRadius="130" IsClippedToBounds="True"
                   IsVisible="{OnPlatform False, iOS=True}">
                <Image Aspect="AspectFill" HeightRequest="260" WidthRequest="260"
                       Source="img_22.jpg" />
            </Frame>

            <Grid Grid.Row="1" Padding="28" RowDefinitions="*,Auto">
                <VerticalStackLayout Grid.Row="0" Spacing="20" VerticalOptions="Center">
                    <Label Text="💧 Meter Reading Made Simple"
                           FontSize="30" FontFamily="OpenSansSemibold"
                           LineHeight="1.2" TextColor="White" />
                    <Label Text="Capture, sync, and manage all your meter readings — fast, reliable, and offline-ready."
                           FontSize="16" LineHeight="1.5"
                           HorizontalTextAlignment="Center" TextColor="#AABDE8F5" />
                </VerticalStackLayout>
                <!-- Button_Clicked kept -->
                <Button Grid.Row="1" Text="Get Started 🌊"
                        Clicked="Button_Clicked"
                        BackgroundColor="#2DD4BF" TextColor="#061929"
                        FontFamily="OpenSansSemibold" CornerRadius="14" HeightRequest="52" />
            </Grid>
        </Grid>
    </Grid>
</ContentPage>
