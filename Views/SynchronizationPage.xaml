<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:skia="clr-namespace:SkiaSharp.Extended.UI.Controls;assembly=SkiaSharp.Extended.UI"
             x:Class="SampleMauiMvvmApp.Views.SynchronizationPage"
             Shell.NavBarIsVisible="False"
             Shell.FlyoutBehavior="Disabled"
             BackgroundColor="#030E18">

    <Shell.BackButtonBehavior>
        <BackButtonBehavior IsEnabled="False" IsVisible="False" />
    </Shell.BackButtonBehavior>

    <Grid>
        <!-- Deep ocean gradient -->
        <BoxView>
            <BoxView.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0.6,1">
                    <GradientStop Color="#030E18" Offset="0.0" />
                    <GradientStop Color="#061929" Offset="0.35" />
                    <GradientStop Color="#0A2342" Offset="0.65" />
                    <GradientStop Color="#0E4C7A" Offset="1.0" />
                </LinearGradientBrush>
            </BoxView.Background>
        </BoxView>

        <!-- Ripple circles -->
        <Ellipse Fill="#0D2AABEE" WidthRequest="300" HeightRequest="300"
                 HorizontalOptions="End" VerticalOptions="Start"
                 Margin="0,-90,-70,0" />
        <Ellipse Fill="#072DD4BF" WidthRequest="200" HeightRequest="200"
                 HorizontalOptions="Start" VerticalOptions="End"
                 Margin="-70,0,0,-70" />

        <!-- Centred content -->
        <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center"
                             Spacing="20" Padding="32,0">

            <!-- Lottie animation — restored exactly as original -->
            <Border BackgroundColor="#221A9BC7"
                    StrokeShape="RoundRectangle 40" StrokeThickness="0"
                    Padding="20" WidthRequest="160" HeightRequest="160"
                    HorizontalOptions="Center">
                <skia:SKLottieView Source="sync_animation.json"
                                   RepeatCount="-1"
                                   HeightRequest="120" WidthRequest="120"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" />
            </Border>

            <Label Text="💧 Meter Reader"
                   FontSize="22" FontFamily="OpenSansSemibold"
                   TextColor="RoyalBlue" HorizontalOptions="Center" />

            <!-- Readable subtitle -->
            <Label Text="Please wait…"
                   FontSize="15" FontFamily="OpenSansSemibold"
                   TextColor="DodgerBlue"
                   HorizontalOptions="Center" />

            <!--<Label Text="Omaruru Town Council"
                   FontSize="13" TextColor="#99B3E8F5"
                   HorizontalOptions="Center" />-->

            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               Color="#7CE3FA"
                               HorizontalOptions="Center"
                               Margin="0,4,0,0" />
        </VerticalStackLayout>
    </Grid>
</ContentPage>
